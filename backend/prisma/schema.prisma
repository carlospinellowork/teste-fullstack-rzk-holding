generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PayableStatus {
  PENDING
  PAID
}

enum ReceivableStatus {
  PENDING
  RECEIVED
}

model Payable {
  id          String        @id @default(uuid())
  provider    String
  description String?
  amount      Float
  due_date    DateTime
  category    String?
  status      PayableStatus @default(PENDING)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  @@map("payables")
}

model Receivable {
  id          String           @id @default(uuid())
  client      String
  description String?
  amount      Float
  due_date    DateTime
  category    String?
  status      ReceivableStatus @default(PENDING)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  @@map("receivables")
}
